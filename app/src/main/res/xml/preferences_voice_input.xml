<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <Preference
        android:icon="@drawable/header_voice_input"
        android:layout="@layout/preference_material_header"
        android:selectable="false" />

    <SwitchPreferenceCompat
        android:defaultValue="true"
        android:key="voice_input"
        android:summary="@string/pref_voice_input_summary"
        android:title="@string/pref_voice_input"
        app:iconSpaceReserved="false"
        app:layout="@layout/preference_material_switch_bar"
        tools:widgetLayout="@layout/preference_material_switch" />


    <PreferenceCategory
        android:layout="@layout/preference_material_category"
        android:title="@string/pref_category_advanced"
        app:allowDividerAbove="false" />

    <SwitchPreferenceCompat
        android:defaultValue="false"
        android:dependency="voice_input"
        android:key="voice_input_root"
        android:summary="@string/pref_voice_input_root_summary"
        android:title="@string/pref_voice_input_root"
        app:iconSpaceReserved="false"
        app:layout="@layout/preference_material_single"
        tools:widgetLayout="@layout/preference_material_switch" />

    <Preference
        android:icon="@drawable/ic_info"
        android:layout="@layout/preference_material_info_top"
        android:selectable="false"
        android:title="@string/pref_voice_input_summary" />
</androidx.preference.PreferenceScreen>